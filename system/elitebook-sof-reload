#!/usr/bin/env bash
# Reload the SOF stack so the patched snd-sof-intel-hda-generic takes effect
# WITHOUT a reboot. PCI-unbind first (releases the xe/HDMI component), then
# remove + reload modules, then rebind. Run as root; pipewire must be stopped.
set -uo pipefail
PCI=0000:00:1f.3
PCIDRV=/sys/bus/pci/drivers/sof-audio-pci-intel-ptl

echo "==> PCI unbind $PCI (tears down card + xe component)"
[[ -e "$PCIDRV/$PCI" ]] && echo "$PCI" > "$PCIDRV/unbind"; sleep 2

echo "==> Removing SOF/SoundWire modules (so the patched generic can reload)"
modprobe -r \
  snd_soc_sof_sdw snd_soc_tas2783_sdw snd_soc_rt712_sdca \
  snd_sof_pci_intel_ptl snd_sof_pci_intel_lnl snd_sof_pci_intel_mtl \
  snd_sof_intel_hda_generic snd_sof_probes 2>&1 | sed 's/^/   /'
if lsmod | grep -q '^snd_sof_intel_hda_generic'; then
    echo "   generic still loaded; removing deeper users"
    modprobe -r snd_sof_intel_hda_common snd_sof_intel_hda snd_sof_intel_hda_sdw_bpt \
        soundwire_intel snd_sof_intel_hda_mlink snd_sof_pci snd_sof 2>&1 | sed 's/^/   /'
    modprobe -r snd_sof_intel_hda_generic 2>&1 | sed 's/^/   /'
fi
echo "   generic loaded now? $(lsmod | grep -c '^snd_sof_intel_hda_generic') (want 0)"

echo "==> Reloading (pulls patched generic + rebinds PCI device)"
modprobe snd_sof_pci_intel_ptl 2>&1 | sed 's/^/   /'
modprobe snd_soc_sof_sdw 2>&1 | sed 's/^/   /'
# ensure device is bound
[[ -e "$PCIDRV/$PCI" ]] || echo "$PCI" > "$PCIDRV/bind" 2>/dev/null
sleep 7

echo "==> Result:"
journalctl -k --since "20 seconds ago" --no-pager 2>/dev/null \
  | grep -iE "loading topology|4amp|sdca-.*amp|Speaker|tas2783|initialization timed out|cfg-amp" | tail -25 | sed 's/^/   /'
echo "==> Playback devices:"
aplay -l 2>/dev/null | grep -iE "card 0|Speaker" | sed 's/^/   /'
echo "DONE"
